@model New_project_2.Models.Listing
@{
    ViewData["Title"] = "Детайли по оябвата";
    var related = ViewData["Related"] as List<New_project_2.Models.Listing> ?? new List<New_project_2.Models.Listing>();
}

<div class="row g-4">
    <div class="col-lg-7">
        <div class="details-image-wrap rounded-4 overflow-hidden">
            <img src="@Model.ImageUrl" class="w-100" alt="@Model.Title" />
        </div>
    </div>

    <div class="col-lg-5">
        <div class="surface-card p-4 rounded-4 h-100">
            <span class="badge text-bg-light mb-2">@Model.Category</span>
            <h1 class="h3 fw-bold">@Model.Title</h1>
            <p class="h3 text-primary fw-bold">$@Model.Price</p>
            <p class="text-muted">@Model.Description</p>

            <div class="seller-box p-3 rounded-4 my-4">
                <p class="mb-1 fw-semibold">Продавач: @Model.Seller?.Username</p>
                <small class="text-muted d-block">Имейл на продавача: @Model.Seller?.Email</small>
            </div>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-controller="Messages" asp-action="Index" asp-route-listingId="@Model.Id" asp-route-sellerId="@Model.SellerId" class="btn btn-primary w-100 btn-lg">Свържи се с продавача</a>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="@Context.Request.Path" class="btn btn-primary w-100 btn-lg">Влез за да пишеш</a>
            }
        </div>
    </div>
</div>

@if (related.Any())
{
    <section class="mt-5">
        <h2 class="h5 mb-3">Подобни обяви</h2>
        <div class="row g-4">
            @foreach (var item in related)
            {
                <div class="col-md-4">
                    <article class="listing-card card border-0 h-100">
                        <img src="@item.ImageUrl" class="card-img-top" alt="@item.Title" />
                        <div class="card-body">
                            <h3 class="h6">@item.Title</h3>
                            <p class="text-primary fw-bold mb-2">$@item.Price</p>
                            <a asp-controller="Listings" asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-dark btn-sm">Отвори</a>
                        </div>
                    </article>
                </div>
            }
        </div>
    </section>
}
