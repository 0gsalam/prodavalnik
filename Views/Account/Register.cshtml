@model New_project_2.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Регистрация";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="surface-card p-4 p-lg-5 rounded-4">
            <h1 class="h4 mb-4">Създай твоя Prodavalnik профил</h1>
            <form method="post" asp-action="Register" asp-controller="Account">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                <div class="mb-3">
                    <label asp-for="Username" class="form-label">Име</label>
                    <input asp-for="Username" class="form-control" placeholder="Въведете име" />
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Email" class="form-label">Имейл</label>
                    <input asp-for="Email" class="form-control" placeholder="name@mail.com" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Password" class="form-label">Парола</label>
                    <input asp-for="Password" class="form-control" placeholder="Създай парола" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label">Повтори парола</label>
                    <input asp-for="ConfirmPassword" class="form-control" placeholder="Повтори парола" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>
                <button class="btn btn-primary w-100 mb-3" type="submit">Регистрация</button>
                <p class="text-center text-muted mb-0">Вече сте регистриран? <a asp-controller="Account" asp-action="Login">Вход</a></p>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
