@model IEnumerable<New_project_2.Models.Listing>
@{
    ViewData["Title"] = "Home";
}

<section class="hero-section rounded-4 p-4 p-lg-5 mb-4">
    <div class="row align-items-center g-4">
        <div class="col-lg-7">
            <span class="badge text-bg-light mb-3">Local marketplace</span>
            <h1 class="display-6 fw-bold mb-3">Buy, sell, and chat instantly on Prodavalnik.</h1>
            <p class="text-muted mb-4">Discover fresh listings near you and post products in minutes.</p>
            <div class="d-flex gap-2 flex-wrap">
                <a asp-controller="Listings" asp-action="Index" class="btn btn-primary btn-lg">Browse Listings</a>
                <a asp-controller="Listings" asp-action="Create" class="btn btn-outline-dark btn-lg">Post Ad</a>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="stats-card p-4 rounded-4">
                <div class="row g-3">
                    <div class="col-4">
                        <p class="small text-muted mb-1">Ads</p>
                        <p class="h4 mb-0">@Model.Count()</p>
                    </div>
                    <div class="col-4">
                        <p class="small text-muted mb-1">Users</p>
                        <p class="h4 mb-0">2+</p>
                    </div>
                    <div class="col-4">
                        <p class="small text-muted mb-1">Cities</p>
                        <p class="h4 mb-0">G. Oryahovitza</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section>
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h4 mb-0">Featured Listings</h2>
        <a asp-controller="Listings" asp-action="Index" class="text-decoration-none fw-semibold">See all</a>
    </div>
    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-sm-6 col-lg-3">
                <article class="listing-card card h-100 border-0">
                    <img src="@item.ImageUrl" class="card-img-top" alt="@item.Title" />
                    <div class="card-body d-flex flex-column">
                        <span class="badge rounded-pill text-bg-light align-self-start mb-2">@item.Category</span>
                        <h3 class="h6 fw-bold">@item.Title</h3>
                        <p class="text-primary fw-bold mb-2">$@item.Price</p>
                        <p class="text-muted small mb-3">@item.Description</p>
                        <a asp-controller="Listings" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-dark mt-auto">View Listing</a>
                    </div>
                </article>
            </div>
        }
    </div>
</section>
