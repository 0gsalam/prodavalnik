@model New_project_2.ViewModels.MessagesPageViewModel
@{
    ViewData["Title"] = "Съобщения";
}

<div class="messages-shell rounded-4 overflow-hidden">
    <div class="row g-0">
        <aside class="col-md-4 col-lg-3 messages-list border-end">
            <div class="p-3 border-bottom fw-semibold">Чатове</div>
            <div class="list-group list-group-flush">
                @if (Model.Conversations.Count == 0)
                {
                    <div class="p-3 text-muted small">Все още нямаш чатове. Отвори обява и натисни Свържи се с продавача.</div>
                }
                else
                {
                    foreach (var c in Model.Conversations)
                    {
                        var isActive = Model.ActiveConversationId == c.Id;
                        <a asp-controller="Messages" asp-action="Index" asp-route-conversationId="@c.Id" class="list-group-item list-group-item-action @(isActive ? "active" : "")">
                            <div class="d-flex w-100 justify-content-between">
                                <strong>@c.PartnerName</strong>
                                <small>@c.LastAtUtc.ToLocalTime().ToString("HH:mm")</small>
                            </div>
                            <small class="d-block">@c.ListingTitle</small>
                            <small>@c.LastMessage</small>
                        </a>
                    }
                }
            </div>
        </aside>

        <section class="col-md-8 col-lg-9 d-flex flex-column chat-window">
            @if (Model.ActiveConversationId is null)
            {
                <div class="p-4 text-muted">Избери чат и започни да пишеш.</div>
            }
            else
            {
                <div class="p-3 border-bottom">
                    <div class="fw-semibold">@Model.ActivePartnerName</div>
                    <small class="text-muted">@Model.ActiveListingTitle</small>
                </div>

                <div class="chat-body p-3 flex-grow-1">
                    @if (Model.Messages.Count == 0)
                    {
                        <div class="text-muted small">Все още няма съобщения. Кажи Здравей !</div>
                    }
                    else
                    {
                        foreach (var m in Model.Messages)
                        {
                            <div class="chat-bubble @(m.IsMine ? "chat-me" : "chat-them") mb-3">
                                <div class="small fw-semibold mb-1">@m.SenderName</div>
                                <div>@m.Content</div>
                            </div>
                        }
                    }
                </div>

                <div class="p-3 border-top">
                    <form method="post" asp-controller="Messages" asp-action="Send">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="conversationId" value="@Model.ActiveConversationId" />
                        <div class="input-group">
                            <input class="form-control" name="newMessageText" placeholder="Напиши съобщение" maxlength="1000" autocomplete="off" />
                            <button class="btn btn-primary" type="submit">Изпрати</button>
                        </div>
                    </form>
                </div>
            }
        </section>
    </div>
</div>
