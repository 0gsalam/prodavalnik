@model New_project_2.ViewModels.AdminAccessViewModel
@{
    ViewData["Title"] = "Admin Access";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-4">
        <div class="surface-card p-4 rounded-4">
            <h1 class="h5 mb-3">Admin Password</h1>
            <p class="text-muted small">Enter admin password to open the dashboard.</p>

            <form method="post" asp-action="Unlock">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
                <button class="btn btn-primary w-100" type="submit">Unlock Admin</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
